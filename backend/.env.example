SERVER_PORT=8081

# CMS dashboard JWT (HS256). If set, all CMS routes require Authorization: Bearer <token>
CMS_JWT_SECRET=
# First user when cms_users is empty (password min 8 chars). Example: admin@local.test / Admin123!
CMS_BOOTSTRAP_EMAIL=
CMS_BOOTSTRAP_PASSWORD=
# UUID of a CMS "General inquiries" project — used when the Contact form (or public API) omits projectId
CMS_GENERAL_INQUIRIES_PROJECT_ID=
DATABASE_HOST=localhost
DATABASE_PORT=5434
DATABASE_USER=somsuit
DATABASE_PASSWORD=Somsuit@2026
DATABASE_NAME=somsuit_db
DATABASE_SSLMODE=disable
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Quotation PDF branding (optional)
COMPANY_NAME=Somsuite Technology
COMPANY_TAGLINE=Innovative technology solutions
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
# PNG/JPG for quotation & contract PDF headers. Leave empty to auto-detect repo public/logo.png
# (from backend cwd: ../public/logo.png). In Docker set e.g. /app/public/logo.png
COMPANY_LOGO_PATH=
