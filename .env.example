# Frontend — VITE_* exposed to the client where used
VITE_API_BASE_URL=http://localhost:4000

# Go CMS for /dashboard:
# - Leave NEXT_PUBLIC_CMS_API_URL empty → browser calls /cms-api/* (Next rewrites to CMS_BACKEND_INTERNAL_URL).
# - Or set full URL, e.g. http://127.0.0.1:8081, if you do not use the proxy.
NEXT_PUBLIC_CMS_API_URL=
# Port must match Go SERVER_PORT (used only by next.config rewrites)
CMS_BACKEND_INTERNAL_URL=http://127.0.0.1:8081
